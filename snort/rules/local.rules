# ============================================================
# LOCAL RULES - PROJECT PESBUK
# File: /etc/snort/rules/local.rules
# Catatan: tanpa http_inspect, gunakan content biasa (raw TCP payload)
# ============================================================

# Test: deteksi semua koneksi TCP ke port 3000
alert tcp any any -> any 3000 (msg:"TEST DOCKER DETECT"; sid:5555555; rev:1;)

# SQLi: deteksi pola OR 1=1 di payload
alert tcp any any -> any 3000 (msg:"SQLi OR 1=1 DETECTED"; \
flow:to_server,established; \
content:"or"; nocase; \
content:"1=1"; nocase; \
sid:1000002; rev:2;)

# SQLi: deteksi encoding %3D (tanda =) yang biasa dipakai attacker
alert tcp any any -> any 3000 (msg:"SQLi ENCODED DETECTED"; \
flow:to_server,established; \
content:"%3D1"; \
sid:1000011; rev:1;)

# Deteksi POST login (monitor semua login attempt)
alert tcp any any -> any 3000 (msg:"POST LOGIN DETECTED"; \
flow:to_server,established; \
content:"username"; \
sid:1234568; rev:1;)

# Brute force: deteksi banyak POST ke /login.php
alert tcp any any -> any 3000 (msg:"POSSIBLE BRUTE FORCE LOGIN"; \
flow:to_server,established; \
content:"POST"; \
content:"/login.php"; \
sid:1234569; rev:1;)

# ============================================================
# NMAP SCAN DETECTION
# Nmap mengirim paket TCP khusus untuk deteksi port terbuka
# ============================================================

# Nmap SYN Scan (-sS): banyak paket SYN tanpa melengkapi handshake
# Threshold: alert jika >5 SYN dari sumber yang sama dalam 2 detik
alert tcp any any -> any any (msg:"NMAP SYN SCAN DETECTED"; \
flags:S,12; \
threshold:type threshold, track by_src, count 5, seconds 2; \
classtype:attempted-recon; \
sid:2000001; rev:1;)

# Nmap NULL Scan (-sN): paket TCP tanpa flag sama sekali
# Tujuan: cek respons port — open port biasanya tidak reply
alert tcp any any -> any any (msg:"NMAP NULL SCAN DETECTED"; \
flags:0; \
classtype:attempted-recon; \
sid:2000002; rev:1;)

# Nmap XMAS Scan (-sX): kirim FIN+PSH+URG sekaligus
# Nama "christmas tree" karena semua flag menyala seperti lampu natal
alert tcp any any -> any any (msg:"NMAP XMAS SCAN DETECTED"; \
flags:FPU,12; \
classtype:attempted-recon; \
sid:2000003; rev:1;)

# Nmap FIN Scan (-sF): hanya kirim FIN flag
# Port tertutup akan balas RST, port terbuka diam saja
alert tcp any any -> any any (msg:"NMAP FIN SCAN DETECTED"; \
flags:F,12; \
classtype:attempted-recon; \
sid:2000004; rev:1;)
